{
    "name": "non-convex-labs/laravel-commonplace",
    "description": "A personal markdown knowledge vault for Laravel — wikilinks, version history, semantic search, and MCP for Claude Code.",
    "keywords": [
        "laravel",
        "knowledge-base",
        "vault",
        "obsidian",
        "wikilinks",
        "markdown",
        "pgvector",
        "semantic-search",
        "mcp",
        "commonplace"
    ],
    "homepage": "https://github.com/non-convex-labs/laravel-commonplace",
    "license": "MIT",
    "authors": [
        {
            "name": "Aaron Addrick",
            "email": "aaddrick@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "elgigi/commonmark-emoji": "^2.0",
        "illuminate/contracts": "^13.0",
        "laravel/mcp": "^0.7.0",
        "league/commonmark": "^2.8",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/yaml": "^7.2",
        "tempest/highlight": "^2.17"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "NonConvexLabs\\Commonplace\\": "src/",
            "NonConvexLabs\\Commonplace\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NonConvexLabs\\Commonplace\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "NonConvexLabs\\Commonplace\\CommonplaceServiceProvider"
            ],
            "aliases": {
                "Commonplace": "NonConvexLabs\\Commonplace\\Facades\\Commonplace"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
