# Local smoke-test env file. Copy to .env.smoke (gitignored) and fill in the
# keys for the driver(s) you want to exercise:
#
#   cp .env.smoke.example .env.smoke
#   $EDITOR .env.smoke
#   set -a && source .env.smoke && set +a
#   vendor/bin/phpunit --group=smoke
#
# Each driver's test self-skips when its key is missing, so you only need to
# fill in the providers you care about.

# Master gate — without this, every smoke test self-skips.
COMMONPLACE_SMOKE_TEST=1

# Voyage
VOYAGE_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Cohere
COHERE_API_KEY=

# Bedrock. Opt-in is explicit because the AWS SDK reads from a credential
# chain (env vars, ~/.aws/credentials, IAM roles); the COMMONPLACE_SMOKE_TEST_BEDROCK
# flag is your acknowledgement that creds are wired up before billing kicks in.
COMMONPLACE_SMOKE_TEST_BEDROCK=0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BEDROCK_REGION=us-east-1
